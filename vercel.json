{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-hostinger-backend-url.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/admin-dashboard/$1"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/admin-dashboard/",
      "permanent": true
    }
  ]
}
